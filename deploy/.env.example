# Production deployment environment variables
# Copy to .env and configure for your environment

# Webhook (verifier -> control plane alerts)
WEBHOOK_SECRET=<min-32-chars-secure-secret>

# OTel / SIEM (optional)
SIEM_OTLP_HTTP_ENDPOINT=https://siem.example.com/v1/otlp
SIEM_OTLP_HTTP_TOKEN=<token>
SPLUNK_HEC_ENDPOINT=https://splunk.example.com:8088/services/collector
SPLUNK_HEC_TOKEN=<token>
LOKI_ENDPOINT=https://loki.example.com/loki/api/v1/push
