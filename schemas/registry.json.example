{
  "endpoints": {
    "api.openai.com": {
      "POST": {
        "/v1/chat/completions": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "required": ["model"],
          "properties": {
            "model": { "type": "string" },
            "messages": { "type": "array" },
            "max_tokens": { "type": "integer", "minimum": 1 }
          }
        }
      }
    }
  }
}
